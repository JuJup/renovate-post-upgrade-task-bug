{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["config:best-practices"],

    "packageRules": [
        {
            "description": "Python Dev Dependencies | Automerge Dev/Test Groups in pyproject.toml files",
            "matchManagers": ["pep621"],
            "matchDepTypes": ["dependency-groups"],
            "matchJsonata": ["managerData.depGroup = 'dev'"],
            "automerge": true,
            "autoApprove": true
        },
        {
            "description": "Py Project 0 | General settings",
            "matchFileNames": ["py-project0/**"],
            "extends": ["schedule:weekly"]
        },
        {
            "description": "Py Project 1 | General settings for Python Dependencies",
            "matchFileNames": ["py-project1/**"],
            "extends": ["schedule:quarterly"]
        },
        {
            "description": "Py Project 2 | General settings for Python Dependencies",
            "matchFileNames": ["py-project2/**"],
            "extends": ["schedule:monthly"],
            "postUpgradeTasks": {
                "commands": ["echo 'Running Post Upgrade Task'"],
                "executionMode": "branch"
            }
        }
    ]
}
